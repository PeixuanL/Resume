" w:sz="1" w:space="1"/></w:pBdr><w:spacing w:after="120" w:before="120"/></w:pPr></w:p><w:p><w:pPr><w:spacing w:after="160" w:before="280"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="534AB7"/><w:spacing w:val="80"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">求职意向</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="20" w:before="40"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="2D2D2D"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve">B端产品经理 / AI产品经理</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="666666"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve"> — 数字孪生 · 工业互联网 · 智能运维方向</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60" w:before="60"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="999999"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve">接受北京 / 远程 / 海外项目制</w:t></w:r></w:p><w:p><w:pPr><w:pBdr><w:bottom w:val="single" w:color="CCCCCC" w:sz="1" w:space="1"/></w:pBdr><w:spacing w:after="120" w:before="120"/></w:pPr></w:p><w:p><w:pPr><w:spacing w:after="160" w:before="280"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="534AB7"/><w:spacing w:val="80"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">个人总结</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60" w:before="80"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="2D2D2D"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve">建筑学出身的产品经理，擅长将空间复杂度抽象为可交付的系统架构。从建筑设计的「需求解构→方案推演→落地验证」训练中，形成了对B端产品同样有效的方法论：先把混沌的业务现场拆解为结构化问题，再做标品化交付。</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60" w:before="60"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="2D2D2D"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve">在 DataMesh 主导数字孪生运维底座从 0 到 1 孵化，5 个月内推动产品从 Demo 达到商用交付状态，支撑海外标杆客户实施周期压缩 60%+。核心方向：设施运维 Agent 化业务闭环，工业仿真编辑器交付提效。致力于标准化实施、业务闭环与规模化交付。</w:t></w:r></w:p><w:p><w:pPr><w:pBdr><w:bottom w:val="single" w:color="CCCCCC" w:sz="1" w:space="1"/></w:pBdr><w:spacing w:after="120" w:before="120"/></w:pPr></w:p><w:p><w:pPr><w:spacing w:after="160" w:before="280"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="534AB7"/><w:spacing w:val="80"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">核心能力</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80" w:before="80"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="534AB7"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve">AI 产品化与业务闭环：</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="2D2D2D"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve"> 构建 B 端 LLM/Agent 可交付体系——不只是做 Prompt，而是设计告警→诊断→处置的完整 Agent 分工、RAG 知识库联动与人工兜底机制，按场景验收持续迭代。</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80" w:before="80"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="534AB7"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve">标品化与路线取舍：</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="2D2D2D"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve"> 从大客户定制项目中提炼通用模块与实施基线，而非逐个项目做加法——实现约 70% 定制需求向标品转化，降低重复研发与沟通成本。</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="80" w:before="80"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="534AB7"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve">验证驱动的交付协同：</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="2D2D2D"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve"> 定义 POC 范围与成功标准，以可验证里程碑推动试点→复制→规模化落地，配合售前推动 POC 转正式合同。</w:t></w:r></w:p><w:p><w:pPr><w:pBdr><w:bottom w:val="single" w:color="CCCCCC" w:sz="1" w:space="1"/></w:pBdr><w:spacing w:after="120" w:before="120"/></w:pPr></w:p><w:p><w:pPr><w:spacing w:after="160" w:before="280"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="534AB7"/><w:spacing w:val="80"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">工作经历</w:t></w:r></w:p><w:p><w:pPr><w:tabs><w:tab w:val="right" w:pos="9706"/></w:tabs><w:spacing w:after="80" w:before="200"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="1A1A2E"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">DataMesh</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="666666"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve"> — B端产品经理</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="999999"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve">	2024.12 - 至今</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60" w:before="60"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="666666"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve">负责数字孪生设施运维（Inspector）、工业仿真编辑（Designer）、MR 工厂培训（Director）三条产品线的规划与落地。</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60" w:before="60"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="1A1A2E"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve">产品规划与生命周期管理</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="2D2D2D"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve">3 条产品线、11 个版本迭代的完整生命周期管理。接手 Inspector 后 1 个月内协同研发交付核心业务场景 Demo，次月推动 MVP 达到可面客验证与商用交付状态，支撑大客户实施与复制落地。</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60" w:before="60"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="1A1A2E"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve">业务梳理与标品转化</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="2D2D2D"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve">围绕佛吉亚灯塔工厂、头部通信运营商等大客户项目，提取通用业务逻辑并优化功能架构。70% 定制需求向标品转化，剩余 30% 因数据接口差异与合规要求保留定制通道。</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60" w:before="60"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="1A1A2E"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve">跨部门协同与产研决策</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="2D2D2D"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve">支撑市场、售前及客户成功团队完成 10+ 重点项目面客需求调研、产品介绍与项目交付。资源受限时评估优先级并提供替代方案，协调前后端研发、美术、测试等多团队保障交付。</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60" w:before="60"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="1A1A2E"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve">售前方案与演示资产</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="2D2D2D"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve">协助撰写丰田、澳洲 Goodman 等 10+ 份售前方案；制作各产品线 Demo 视频及售前 PPT，拉齐售前产研与交付口径。</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60" w:before="60"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="1A1A2E"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve">POC 设计与商务验证闭环</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="2D2D2D"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve">定义 POC 范围、成功标准与试点节奏。为日本领先制药、电力、建工等跨境客户提供产品与技术沟通支持；配合售前推动某日本头部建工企业项目由 POC 转入正式合同。</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="60" w:before="60"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="1A1A2E"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve">流程优化与团队赋能</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="2D2D2D"/><w:sz w:val="20"/><w:szCs w:val="20"/></w:rPr><w:t xml:space="preserve">制定 4 份发布指导与产品验收 SOP，重构标准资源包（DLC）线上发布流程——发布周期由 4 周缩短至 1–2 周，交付提效约 75%。沉淀跨产品线交付清单与培训要点，赋能销售与交付团队复用。</w:t></w:r></w:p><w:p><w:pPr><w:pBdr><w:bottom w:val="single" w:color="CCCCCC" w:sz="1" w:space="1"/></w:pBdr><w:spacing w:after="120" w:before="120"/></w:pPr></w:p><w:p><w:pPr><w:spacing w:after="160" w:before="280"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="534AB7"/><w:spacing w:val="80"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">项目经历</w:t></w:r></w:p><w:p><w:pPr><w:tabs><w:tab w:val="right" w:pos="9706"/></w:tabs><w:spacing w:after="80" w:before="200"/></w:pPr><w:r><w:rPr><w:rFonts w:asci